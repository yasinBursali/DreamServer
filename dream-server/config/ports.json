{
  "version": "1.0.0",
  "description": "Canonical external port contract for Dream Server services.",
  "ports": [
    {
      "env": "OLLAMA_PORT",
      "default": 8080,
      "service_id": "llama-server",
      "container_port": 8080
    },
    {
      "env": "WEBUI_PORT",
      "default": 3000,
      "service_id": "open-webui",
      "container_port": 8080
    },
    {
      "env": "SEARXNG_PORT",
      "default": 8888,
      "service_id": "searxng",
      "container_port": 8080
    },
    {
      "env": "PERPLEXICA_PORT",
      "default": 3004,
      "service_id": "perplexica",
      "container_port": 3000
    },
    {
      "env": "WHISPER_PORT",
      "default": 9000,
      "service_id": "whisper",
      "container_port": 8000
    },
    {
      "env": "TTS_PORT",
      "default": 8880,
      "service_id": "tts",
      "container_port": 8880
    },
    {
      "env": "N8N_PORT",
      "default": 5678,
      "service_id": "n8n",
      "container_port": 5678
    },
    {
      "env": "QDRANT_PORT",
      "default": 6333,
      "service_id": "qdrant",
      "container_port": 6333
    },
    {
      "env": "QDRANT_GRPC_PORT",
      "default": 6334,
      "service_id": "qdrant",
      "container_port": 6334,
      "skip_manifest": true
    },
    {
      "env": "EMBEDDINGS_PORT",
      "default": 8090,
      "service_id": "embeddings",
      "container_port": 80
    },
    {
      "env": "LITELLM_PORT",
      "default": 4000,
      "service_id": "litellm",
      "container_port": 4000
    },
    {
      "env": "OPENCLAW_PORT",
      "default": 7860,
      "service_id": "openclaw",
      "container_port": 18789
    },
    {
      "env": "SHIELD_PORT",
      "default": 8085,
      "service_id": "privacy-shield",
      "container_port": 8085
    },
    {
      "env": "DASHBOARD_API_PORT",
      "default": 3002,
      "service_id": "dashboard-api",
      "container_port": 3002
    },
    {
      "env": "DASHBOARD_PORT",
      "default": 3001,
      "service_id": "dashboard",
      "container_port": 3001
    },
    {
      "env": "COMFYUI_PORT",
      "default": 8188,
      "service_id": "comfyui",
      "container_port": 8188
    },
    {
      "env": "TOKEN_SPY_PORT",
      "default": 3005,
      "service_id": "token-spy",
      "container_port": 8080
    },
    {
      "env": "OPENCODE_PORT",
      "default": 3003,
      "service_id": "opencode",
      "container_port": 3003,
      "require_compose": false
    }
  ]
}
