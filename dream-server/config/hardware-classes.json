{
  "version": "1",
  "classes": [
    {
      "id": "strix_unified_large",
      "label": "Strix Halo (90GB+)",
      "match": {
        "platform_id": ["linux", "wsl"],
        "gpu_vendor": ["amd"],
        "memory_type": ["unified"],
        "min_vram_mb": 92160
      },
      "recommended": {
        "backend": "amd",
        "tier": "SH_LARGE",
        "compose_overlays": ["docker-compose.base.yml", "docker-compose.amd.yml"]
      }
    },
